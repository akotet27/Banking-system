# ─── Ishimwe Bank — Environment Configuration ───────────────────────────────
# Copy this file to .env and fill in your values.
# The server reads this file automatically on startup.

# ── Security ──────────────────────────────────────────────────────────────────
# Generate a strong random key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./ishimwe_bank.db

# ── Email / SMTP ──────────────────────────────────────────────────────────────
# To use Gmail:
#   1. Enable 2-Factor Authentication on your Google account
#   2. Go to: Google Account → Security → App Passwords
#   3. Create an App Password for "Mail" — you get a 16-character code
#   4. Paste that code (without spaces) as SMTP_PASSWORD below
#
# To use Outlook / Hotmail:
#   SMTP_HOST=smtp-mail.outlook.com
#   SMTP_PORT=587
#
# Leave SMTP_USER empty to stay in dev mode (OTPs printed to server console).

SMTP_HOST=mail.nexventures.net
SMTP_PORT=587
SMTP_USER=security@nexventures.net
SMTP_SENDER=security@nexventures.net
SMTP_PASSWORD="Ca4*#Syc8Hmzz.P"

# ── OTP ───────────────────────────────────────────────────────────────────────
OTP_EXPIRE_MINUTES=10
OTP_RATE_LIMIT_PER_HOUR=5

# ── Session ───────────────────────────────────────────────────────────────────
SESSION_EXPIRE_MINUTES=3
