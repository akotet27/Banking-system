SECRET_KEY=change-me-in-production-use-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# SQLite for local dev; use a postgres:// URL on Render
DATABASE_URL=sqlite:///./ishimwe_bank.db

# Comma-separated allowed CORS origins
CORS_ORIGINS=http://localhost:5173

OTP_EXPIRE_MINUTES=10
OTP_RATE_LIMIT_PER_HOUR=5

# Leave blank in dev — OTPs will be printed to console instead
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# WebAuthn — match your dev frontend URL
WEBAUTHN_RP_ID=localhost
WEBAUTHN_ORIGIN=http://localhost:5173

# Fee defaults (percentage, e.g. 1.0 = 1%)
CASH_OUT_FEE_PERCENTAGE=1.0
CASH_OUT_MIN_FEE=5.0
SEND_MONEY_FEE_PERCENTAGE=0.5
SEND_MONEY_MIN_FEE=1.0
PAY_MERCHANT_FEE_PERCENTAGE=0.3
PAY_MERCHANT_MIN_FEE=0.5

# 30% of the cash-out fee goes to the agent; 70% is system revenue
AGENT_COMMISSION_PERCENTAGE=30.0

# Max cash-out via agent-device biometric (Path B fallback), in ETB
AGENT_DEVICE_CASHOUT_MAX=5000.0

# Privacy session window in minutes
SESSION_EXPIRE_MINUTES=3
